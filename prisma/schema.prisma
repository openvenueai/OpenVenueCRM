generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// Organization & Venue Layer
// ============================================================================

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  ownerId          String   @map("owner_id")
  stripeAccountId  String?  @map("stripe_account_id")
  settings         Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  venues   Venue[]
  contacts Contact[]

  @@map("organizations")
}

model Venue {
  id       String @id @default(cuid())
  orgId    String @map("org_id")
  name     String
  address  String @default("")
  timezone String @default("America/New_York")
  phone    String?
  email    String?
  website  String?
  settings Json   @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  spaces       Space[]
  leads        Lead[]
  tasks        Task[]

  @@map("venues")
}

model Space {
  id               String   @id @default(cuid())
  venueId          String   @map("venue_id")
  name             String
  description      String?
  capacityMin      Int?     @map("capacity_min")
  capacityMax      Int      @map("capacity_max")
  rentalFee        Decimal? @map("rental_fee") @db.Decimal(10, 2)
  setupMinutes     Int      @default(60) @map("setup_minutes")
  teardownMinutes  Int      @default(60) @map("teardown_minutes")
  color            String   @default("#3B82F6")
  photos           String[] @default([])
  amenities        String[] @default([])
  sortOrder        Int      @default(0) @map("sort_order")
  isActive         Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  venue Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  leads Lead[]

  @@map("spaces")
}

// ============================================================================
// Contacts
// ============================================================================

model Contact {
  id            String   @id @default(cuid())
  orgId         String   @map("org_id")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  email         String
  phone         String?
  company       String?
  tags          String[] @default([])
  source        String?
  notes         String?
  lifetimeValue Decimal  @default(0) @map("lifetime_value") @db.Decimal(10, 2)
  eventCount    Int      @default(0) @map("event_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@map("contacts")
}

// ============================================================================
// Leads (The Central Object)
// ============================================================================

enum LeadStatus {
  INQUIRY
  TOUR_SCHEDULED
  PROPOSAL_SENT
  NEGOTIATION
  CONTRACT_SENT
  CONFIRMED
  COMPLETED
  LOST
  CANCELLED
}

model Lead {
  id             String     @id @default(cuid())
  venueId        String     @map("venue_id")
  contactId      String     @map("contact_id")
  assignedTo     String?    @map("assigned_to")
  spaceId        String?    @map("space_id")
  status         LeadStatus @default(INQUIRY)
  source         String?
  eventType      String     @map("event_type")
  eventName      String?    @map("event_name")
  eventDate      DateTime?  @map("event_date") @db.Date
  eventStart     DateTime?  @map("event_start")
  eventEnd       DateTime?  @map("event_end")
  guestCount     Int?       @map("guest_count")
  budget         Decimal?   @db.Decimal(10, 2)
  totalValue     Decimal    @default(0) @map("total_value") @db.Decimal(10, 2)
  notesSummary   String?    @map("notes_summary")
  lostReason     String?    @map("lost_reason")
  score          Int?
  lastActivityAt DateTime   @default(now()) @map("last_activity_at")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  confirmedAt DateTime? @map("confirmed_at")

  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  space     Space?   @relation(fields: [spaceId], references: [id])

  messages     Message[]
  proposals    Proposal[]
  invoices     Invoice[]
  beos         Beo[]
  tasks        Task[]
  activityLogs ActivityLog[]

  @@map("leads")
}

// ============================================================================
// Communication
// ============================================================================

enum SenderType {
  STAFF
  CLIENT
  SYSTEM
  AI
}

enum MessageChannel {
  EMAIL
  SMS
  INTERNAL_NOTE
  PORTAL
  PHONE_LOG
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model Message {
  id         String           @id @default(cuid())
  leadId     String           @map("lead_id")
  senderType SenderType       @map("sender_type")
  senderId   String?          @map("sender_id")
  channel    MessageChannel
  direction  MessageDirection @default(OUTBOUND)
  subject    String?
  body       String
  isInternal Boolean          @default(false) @map("is_internal")
  externalId String?          @map("external_id")
  metadata   Json?

  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ============================================================================
// Proposals & Contracts
// ============================================================================

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}

model Proposal {
  id              String         @id @default(cuid())
  leadId          String         @map("lead_id")
  version         Int            @default(1)
  status          ProposalStatus @default(DRAFT)
  title           String
  introText       String?        @map("intro_text")
  closingText     String?        @map("closing_text")
  validUntil      DateTime?      @map("valid_until") @db.Date
  subtotal        Decimal        @default(0) @db.Decimal(10, 2)
  taxRate         Decimal        @default(0) @map("tax_rate") @db.Decimal(5, 3)
  taxAmount       Decimal        @default(0) @map("tax_amount") @db.Decimal(10, 2)
  total           Decimal        @default(0) @db.Decimal(10, 2)
  gratuityEnabled Boolean        @default(false) @map("gratuity_enabled")
  sentAt          DateTime?      @map("sent_at")
  viewedAt        DateTime?      @map("viewed_at")
  acceptedAt      DateTime?      @map("accepted_at")
  signatureData   String?        @map("signature_data")
  pdfUrl          String?        @map("pdf_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead     Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sections ProposalSection[]
  invoices Invoice[]

  @@map("proposals")
}

model ProposalSection {
  id          String  @id @default(cuid())
  proposalId  String  @map("proposal_id")
  title       String
  description String?
  sortOrder   Int     @default(0) @map("sort_order")

  proposal  Proposal             @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  lineItems ProposalLineItem[]

  @@map("proposal_sections")
}

model ProposalLineItem {
  id          String  @id @default(cuid())
  sectionId   String  @map("section_id")
  name        String
  description String?
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  unitLabel   String? @map("unit_label")
  total       Decimal @default(0) @db.Decimal(10, 2)
  isOptional  Boolean @default(false) @map("is_optional")
  sortOrder   Int     @default(0) @map("sort_order")

  section ProposalSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("proposal_line_items")
}

// ============================================================================
// Invoices & Payments
// ============================================================================

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id          String        @id @default(cuid())
  leadId      String        @map("lead_id")
  proposalId  String?       @map("proposal_id")
  status      InvoiceStatus @default(DRAFT)
  subtotal    Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount   Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  gratuity    Decimal       @default(0) @db.Decimal(10, 2)
  total       Decimal       @default(0) @db.Decimal(10, 2)
  amountPaid  Decimal       @default(0) @map("amount_paid") @db.Decimal(10, 2)
  amountDue   Decimal       @default(0) @map("amount_due") @db.Decimal(10, 2)
  dueDate     DateTime?     @map("due_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead             Lead                  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  proposal         Proposal?             @relation(fields: [proposalId], references: [id])
  scheduleItems    PaymentScheduleItem[]
  payments         Payment[]

  @@map("invoices")
}

enum PaymentScheduleStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
}

model PaymentScheduleItem {
  id            String                @id @default(cuid())
  invoiceId     String                @map("invoice_id")
  label         String
  amount        Decimal               @db.Decimal(10, 2)
  dueDate       DateTime              @map("due_date") @db.Date
  status        PaymentScheduleStatus @default(PENDING)
  reminderSentAt DateTime?            @map("reminder_sent_at")

  invoice  Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("payment_schedule_items")
}

enum PaymentMethod {
  CREDIT_CARD
  ACH
  CHECK
  CASH
  WIRE
  OTHER
}

enum PaymentStatus {
  SUCCEEDED
  PENDING
  FAILED
  REFUNDED
}

model Payment {
  id              String        @id @default(cuid())
  invoiceId       String        @map("invoice_id")
  scheduleItemId  String?       @map("schedule_item_id")
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod @default(CREDIT_CARD)
  stripePaymentId String?       @map("stripe_payment_id")
  status          PaymentStatus @default(PENDING)
  refundAmount    Decimal?      @map("refund_amount") @db.Decimal(10, 2)
  notes           String?
  paidAt          DateTime      @default(now()) @map("paid_at")

  invoice      Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  scheduleItem PaymentScheduleItem? @relation(fields: [scheduleItemId], references: [id])

  @@map("payments")
}

// ============================================================================
// BEOs (Banquet Event Orders)
// ============================================================================

enum BeoStatus {
  DRAFT
  SENT_TO_CLIENT
  APPROVED
  FINALIZED
}

model Beo {
  id          String    @id @default(cuid())
  leadId      String    @map("lead_id")
  version     Int       @default(1)
  status      BeoStatus @default(DRAFT)
  eventDate   DateTime  @map("event_date") @db.Date
  eventStart  DateTime  @map("event_start")
  eventEnd    DateTime  @map("event_end")
  setupTime   DateTime? @map("setup_time")
  guestCount  Int       @map("guest_count")
  spaceName   String    @map("space_name")
  roomSetup   String?   @map("room_setup")
  content     Json      @default("{}")
  staffNotes  String?   @map("staff_notes")
  clientNotes String?   @map("client_notes")
  pdfUrl      String?   @map("pdf_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("beos")
}

// ============================================================================
// Tasks & Activity Log
// ============================================================================

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskCreatedBy {
  MANUAL
  AUTOMATION
  AI
}

model Task {
  id          String        @id @default(cuid())
  leadId      String?       @map("lead_id")
  venueId     String        @map("venue_id")
  assignedTo  String?       @map("assigned_to")
  title       String
  dueDate     DateTime?     @map("due_date")
  priority    TaskPriority  @default(MEDIUM)
  status      TaskStatus    @default(TODO)
  completedAt DateTime?     @map("completed_at")
  createdBy   TaskCreatedBy @default(MANUAL) @map("created_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead  Lead?  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  venue Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

enum ActorType {
  STAFF
  CLIENT
  SYSTEM
  AI
}

model ActivityLog {
  id          String    @id @default(cuid())
  leadId      String    @map("lead_id")
  actorType   ActorType @map("actor_type")
  actorId     String?   @map("actor_id")
  action      String
  description String
  metadata    Json?

  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

// ============================================================================
// Onboarding
// ============================================================================

enum OnboardingStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model OnboardingSession {
  id             String            @id @default(cuid())
  userId         String            @map("user_id")
  organizationId String?           @map("organization_id")
  currentStepId  String            @map("current_step_id")
  answers        Json              @default("{}")
  status         OnboardingStatus  @default(IN_PROGRESS)
  version        Int               @default(1)

  startedAt   DateTime  @default(now()) @map("started_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  events OnboardingEvent[]

  @@map("onboarding_sessions")
}

model OnboardingEvent {
  id        String @id @default(cuid())
  sessionId String @map("session_id")
  userId    String @map("user_id")
  stepId    String @map("step_id")
  eventType String @map("event_type")
  value     Json?  @map("value_json")

  createdAt DateTime @default(now()) @map("created_at")

  session OnboardingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("onboarding_events")
}
